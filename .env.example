APP_NAME="Xander Learning Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Learner React app — payment return URLs, emails, public cohort join links
# Production: https://xanderglobalacademy.com
# If omitted on cPanel, API auto-uses xanderglobalacademy.com when APP_URL is api.xanderglobalscholars.com
FRONTEND_URL=http://localhost:8080

# Run pending migrations automatically when the API starts (recommended for local dev)
AUTO_MIGRATE=true
# Seed demo instructors/courses/students when none exist (local/testing)
AUTO_SEED_DEMO=true
# Optional secret for POST /api/admin/system/migrate on production
MIGRATE_TOKEN=
# Sample partner institution owner password (PlatformInstitutionSeeder)
SEED_PARTNER_PASSWORD=Partner@2026
# Institution self-signup Stripe fee in cents (default $99)
INSTITUTION_SIGNUP_FEE_CENTS=9900

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Zoom app #1 — Server-to-Server OAuth (REST API: create meetings, recordings)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_USER_ID=me

# Zoom app #2 — General app / Embed (in-browser meetings; separate Client ID & Secret)
# marketplace.zoom.us → your General app → Production → App Credentials
ZOOM_EMBED_CLIENT_ID=
ZOOM_EMBED_CLIENT_SECRET=
# Required Zoom S2S scopes for Recordings page (add in Zoom Marketplace, then re-activate app):
# cloud_recording:read:list_user_recordings:admin
# cloud_recording:read:list_recording_files:admin

# Pathways webinar (Webinar Signups page)
PATHWAYS_TIMEZONE=Africa/Kigali
PATHWAYS_ZOOM_JOIN_URL=
PATHWAYS_ZOOM_MEETING_ID=
PATHWAYS_ZOOM_START_URL=

# Stripe (test keys for development)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xander-elearning
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
# cPanel: use xanderglobalscholars.com (not mail.* — SSL cert mismatch on shared hosting)
MAIL_HOST=xanderglobalscholars.com
MAIL_PORT=465
MAIL_USERNAME=admission@xanderglobalscholars.com
MAIL_PASSWORD=
# Legacy alias — Laravel 12 prefers MAIL_SCHEME=smtps for SSL/465
MAIL_ENCRYPTION=ssl
MAIL_EHLO_DOMAIN=xanderglobalscholars.com
MAIL_VERIFY_PEER=false
MAIL_TIMEOUT=30
MAIL_FROM_ADDRESS=admission@xanderglobalscholars.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# pCloud (course materials storage — token stays server-side only)
PCLOUD_ACCESS_TOKEN=
PCLOUD_ROOT_FOLDER_ID=31887143130
PCLOUD_ROOT_FOLDER=parrotacademy
PCLOUD_API_URL=https://api.pcloud.com
# Optional — leave empty to use PCLOUD_API_URL for uploads (recommended on cPanel)
# PCLOUD_UPLOAD_URL=https://api.pcloud.com
